JW_USERNAME=your_username
JW_PASSWORD=your_password
# Optional debug fallback only. Leave empty for automatic HTTP login.
JW_TOKEN=
# Optional listen address. Defaults to 127.0.0.1:8080 when unset.
APP_ADDR=127.0.0.1:8080
# Gin runtime mode. Use release in production.
GIN_MODE=release
# Optional: set to 1 or true to include source file/line (caller) in log records.
# LOG_CALLER=1
